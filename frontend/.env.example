# ===========================================
# PolyDropBox - Environment Variables
# Copy to .env or frontend/.env.local
# ===========================================

# Blockchain - Contract deployment (Hardhat)
PRIVATE_KEY=your_private_key_here
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology
POLYGON_MAINNET_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Blockchain - Frontend (upload, download, sideshift)
NEXT_PUBLIC_CONTRACT_ADDRESS=0x6f82905eba43Be79c8E7a80056031846d489d50B
NEXT_PUBLIC_USDC_ADDRESS=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
NEXT_PUBLIC_POLYGON_RPC=https://polygon-rpc.com
NEXT_PUBLIC_POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology

# WalletConnect
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id
NEXT_PUBLIC_WC_PROJECT_ID=your_project_id

# Database
MONGODB_URI=mongodb://localhost:27017/polydropbox
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/polydropbox

# IPFS - Pinata (required for upload)
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key

# SideShift - Cross-chain (optional)
# SIDESHIFT_SECRET=your_sideshift_secret

# Production URL - Set to your Render/Vercel URL when deploying
NEXT_PUBLIC_FRONTEND_URL=https://your-app.onrender.com
