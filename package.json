{
  "name": "polydropbox",
  "version": "1.0.0",
  "description": "Decentralized File Sharing with Expiry, Payments & Cross-Chain Swaps",
  "scripts": {
    "build": "cd frontend && npm install && npm run build",
    "start": "cd frontend && npm start",
    "compile": "hardhat compile",
    "deploy": "hardhat run scripts/deploy.js --network amoy",
    "deploy:mainnet": "hardhat run scripts/deploy-mainnet.js --network polygon",
    "test": "hardhat test"
  },
  "dependencies": {
    "next": "14.2.35",
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.3.1",
    "hardhat": "^2.19.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.0"
  }
}

